; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between brackets
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="geometry-tower-defense"
config/version="0.1.0"
run/main_scene="res://src/Main.tscn"
config/features=PackedStringArray("4.7", "C#")
config/icon=""

[display]

window/size/viewport_width=1460
window/size/viewport_height=800
window/size/mode=0
window/size/always_on_top=false

[dotnet]

project/assembly_name="GeometryTowerDefense"

[input]

; Input map will be populated during feature work

[rendering]

textures/canvas_textures/default_texture_filter=2
